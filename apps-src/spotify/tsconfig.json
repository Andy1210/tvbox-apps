{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["node"],
    "paths": {
      "@sdk": ["../../../app-sdk/src/index.ts"],
      "@sdk/*": ["../../../app-sdk/src/*"],
      "react": ["../../node_modules/@types/react"],
      "react/*": ["../../node_modules/@types/react/*"],
      "react-dom": ["../../node_modules/@types/react-dom"],
      "react-dom/*": ["../../node_modules/@types/react-dom/*"],
      "zustand": ["../../node_modules/zustand"],
      "zustand/*": ["../../node_modules/zustand/*"],
      "@noriginmedia/norigin-spatial-navigation": ["../../node_modules/@noriginmedia/norigin-spatial-navigation"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../../app-sdk/src"]
}
