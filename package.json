{
  "name": "tvbox-apps",
  "private": true,
  "type": "module",
  "description": "tvbox app registry — self-contained app packages (manifest + host plugin + built web UI) and their standalone Vite sources.",
  "scripts": {
    "build:livetv": "vite build -c apps-src/livetv/vite.config.ts",
    "typecheck:livetv": "tsc --noEmit -p apps-src/livetv/tsconfig.json",
    "build:spotify": "vite build -c apps-src/spotify/vite.config.ts",
    "typecheck:spotify": "tsc --noEmit -p apps-src/spotify/tsconfig.json",
    "index": "node scripts/build-index.mjs"
  },
  "dependencies": {
    "@noriginmedia/norigin-spatial-navigation": "^3.2.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  }
}
