{
  "registryVersion": 1,
  "apps": [
    {
      "id": "jellyfin",
      "manifestVersion": 1,
      "version": "1.0.0",
      "name": "Jellyfin",
      "type": "webclient",
      "status": "ready",
      "accent": "#00a4dc",
      "icon": "<svg viewBox='0 0 24 24'><rect width='24' height='24' rx='4' fill='#101010'/><path d='M12 6.5c-1.2 0-4.9 6.7-4.3 7.8.6 1.1 8 1.1 8.6 0 .6-1.1-3.1-7.8-4.3-7.8zm0 2.9c.5 0 2 2.7 1.8 3.2-.3.5-3.3.5-3.6 0-.2-.5 1.3-3.2 1.8-3.2z' fill='#00a4dc'/><path d='M12 3.2C9.8 3.2 3.2 15 4.3 17c.4.7 2.1 1 4.1 1.1-.7-.3-1.2-.6-1.4-1-.9-1.6 3.3-9.6 5-9.6s5.9 8 5 9.6c-.2.4-.7.7-1.4 1 2-.1 3.7-.4 4.1-1.1 1.1-2-5.5-13.8-7.7-13.8z' fill='#00a4dc' opacity='.55'/></svg>",
      "tagline": {
        "en": "Movies & TV from your own server",
        "hu": "Filmek és sorozatok a saját szerveredről"
      },
      "description": {
        "en": "The free, self-hosted media server. Point the box at your Jellyfin server and watch your movies, shows and music on the TV, driven by the remote.",
        "hu": "Az ingyenes, saját üzemeltetésű médiaszerver. Add meg a Jellyfin-szervered címét, és nézd a filmjeidet, sorozataidat és zenéidet a TV-n, távirányítóval."
      },
      "runtime": {
        "serve": "remote",
        "urlConfig": "jellyfin",
        "capabilities": [
          "nav"
        ]
      }
    },
    {
      "id": "livetv",
      "manifestVersion": 1,
      "name": {
        "hu": "Élő TV",
        "en": "Live TV"
      },
      "version": "1.0.1",
      "changelog": [
        {
          "version": "1.0.1",
          "notes": "Fixed a black screen when opening the app."
        },
        {
          "version": "1.0.0",
          "notes": "Initial release — IPTV channels, EPG guide, and phone-based setup."
        }
      ],
      "type": "webclient",
      "status": "ready",
      "accent": "#39c0d6",
      "icon": "<svg viewBox='0 0 24 24' fill='none' stroke='#39c0d6' stroke-width='2'><rect x='2.5' y='5' width='19' height='13' rx='2'/><path d='M8 21h8M9 5l3-2 3 2' stroke-linecap='round'/></svg>",
      "tagline": {
        "hu": "IPTV csatornák",
        "en": "IPTV channels"
      },
      "description": {
        "en": "Watch IPTV channels with a full programme guide (EPG), played natively by the box. Set it up with an Xtream Codes login or an M3U playlist plus an XMLTV guide, entered from the TV or by scanning a QR with your phone.",
        "hu": "IPTV-csatornák nézése teljes műsorújsággal (EPG), a videót a box natívan játssza. Beállítás Xtream Codes belépéssel vagy M3U-lejátszási listával és XMLTV-műsorújsággal, a TV-ről vagy telefonos QR-beolvasással megadva."
      },
      "requires": {
        "bin": [
          "mpv"
        ],
        "apt": [
          "mpv"
        ]
      },
      "service": "livetv",
      "runtime": {
        "serve": "local",
        "entry": "index.html",
        "capabilities": [
          "player",
          "nav",
          "config"
        ]
      }
    },
    {
      "id": "plex",
      "manifestVersion": 1,
      "name": "Plex",
      "version": "1.0.0",
      "type": "webclient",
      "status": "ready",
      "accent": "#e5a00d",
      "icon": "<svg viewBox='0 0 512 512'><rect width='512' height='512' rx='15%' fill='#282a2d'/><path d='m256 70h-108l108 186-108 186h108l108-186z' fill='#e5a00d'/></svg>",
      "tagline": {
        "hu": "Filmek és sorozatok",
        "en": "Movies & TV shows"
      },
      "description": {
        "en": "The official Plex 10-foot app. Stream the movies, TV shows and music from your Plex server to the big screen, with the box playing video natively. Sign in once with plex.tv/link, no typing on the TV.",
        "hu": "A hivatalos Plex nappali-app. A Plex-szervereden lévő filmek, sorozatok és zene lejátszása a nagy képernyőn, a videót a box natívan játssza. Egyszeri belépés a plex.tv/link címen, nem kell gépelni a TV-n."
      },
      "requires": {
        "bin": [
          "mpv"
        ],
        "apt": [
          "mpv"
        ]
      },
      "install": {
        "source": {
          "type": "flatpak",
          "ref": "tv.plex.PlexHTPC",
          "arch": "x86_64"
        },
        "extract": "files/resources/web-client",
        "patch": [
          {
            "op": "strip-script",
            "match": "qwebchannel"
          }
        ]
      },
      "runtime": {
        "serve": "static",
        "entry": "index.html",
        "mount": "root",
        "bridge": "qwebchannel",
        "transparentSelector": "#media-container",
        "capabilities": [
          "storage",
          "player",
          "input",
          "system"
        ],
        "player": "mpv-overlay"
      }
    },
    {
